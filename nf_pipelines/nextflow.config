/*
 * nextflow.config
 */

// 1. Define ALL Parameters first so they are available to the blocks below
params {
    // HPC paths
    fastq_dir     = "/mnt/beegfs/home/asalamit/persistent/scdata/fastq_files"
    output_dir    = "/mnt/beegfs/home/asalamit/persistent/starsolo_out"
    genome_dir    = "/mnt/beegfs/home/asalamit/persistent/genomes/xenopus/star_index_v10"

    // Cell barcode whitelists
    cb_whitelist1       = "/mnt/beegfs/home/asalamit/persistent/nf_indrops/inputs/gel_barcode1_list.txt"     // CB1 forward – v2 (unused in STAR, kept for preflight)
    cb_whitelist1_rc    = "/mnt/beegfs/home/asalamit/persistent/nf_indrops/inputs/gel_barcode1_rc_list.txt"  // CB1 reverse complement – v2 BC1
    cb_whitelist2_sense = "/mnt/beegfs/home/asalamit/persistent/nf_indrops/inputs/gel_barcode2_list.txt"     // CB2 forward – v3 BC1, v2 BC2
    cb_whitelist2_rc    = "/mnt/beegfs/home/asalamit/persistent/nf_indrops/inputs/bc2_rc.txt"                // CB2 reverse complement – v3 BC2

    // Resource Defaults (matched to your pipeline script)
    star_threads     = 20
    star_mem         = "32 GB"
    star_time        = "4h"
    cutadapt_threads = 20
    cutadapt_mem     = "12 GB"
    cutadapt_time    = "2h"
    seqtk_mem        = "32 GB"
    seqtk_time       = "4h"
    fastqc_threads   = 6
    fastqc_mem       = "4 GB"
    fastqc_time      = "1h"
    multiqc_mem      = "4 GB"
    multiqc_time     = "30m"
}

// 2. Global Process Settings (Labels & Containers)
process {
    withLabel: 'cutadapt' {
        container = 'docker://quay.io/biocontainers/cutadapt:5.2--py310h1fe012e_0'
        cpus      = params.cutadapt_threads
        memory    = params.cutadapt_mem
        time      = params.cutadapt_time
    }

    withLabel: 'seqtk' {
        container = 'docker://quay.io/biocontainers/seqtk:1.5--h577a1d6_1'
        memory    = params.seqtk_mem
        time      = params.seqtk_time
    }

    withLabel: 'star' {
        module    = 'star/2.7.11b:java/21.0.6'
        cpus      = params.star_threads
        memory    = params.star_mem
        time      = params.star_time
    }

    withLabel: 'fastqc' {
        container = 'quay.io/biocontainers/fastqc:0.11.3--0'
        cpus      = params.fastqc_threads
        memory    = params.fastqc_mem
        time      = params.fastqc_time
    }

    withLabel: 'multiqc' {
        container = 'quay.io/biocontainers/multiqc:1.33--pyhdfd78af_0'
        memory    = params.multiqc_mem
        time      = params.multiqc_time
    }
}

// 3. Profiles for Infrastructure
profiles {
    hpc {
        process {
            executor = 'slurm'
            queue    = 'dev'
        }
        singularity {
            enabled    = true
            autoMounts = true
        }
        workDir = "/mnt/beegfs/home/asalamit/persistent/nf_work"
    }

    local {
        process {
            executor = 'local'
        }
        singularity.enabled = true
    }
}

// 4. Reporting
timeline { enabled = true; file = "pipeline_timeline.html" }
report   { enabled = true; file = "pipeline_report.html" }
