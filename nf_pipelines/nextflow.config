/*
 * nextflow.config
 */

// 1. Define ALL Parameters first so they are available to the blocks below
params {
    // Data paths (override on command line or in a site-specific config)
    fastq_dir     = null
    output_dir    = null
    genome_dir    = null

    // Cell barcode whitelists (bundled defaults)
    cb_whitelist1       = "${projectDir}/../inputs/gel_barcode1_list.txt"      // CB1 forward – v2 (unused in STAR, kept for preflight)
    cb_whitelist1_rc    = "${projectDir}/../inputs/gel_barcode1_rc_list.txt"   // CB1 reverse complement – v2 BC1
    cb_whitelist2_sense = "${projectDir}/../inputs/gel_barcode2_list.txt"      // CB2 forward – v3 BC1, v2 BC2
    cb_whitelist2_rc    = "${projectDir}/../inputs/bc2_rc.txt"                 // CB2 reverse complement – v3 BC2

    // Adapter fasta for gene-read trimming
    adapter_fasta = "${projectDir}/../inputs/illumina_nextseq_p7.fasta"

    // Aligner selection: 'starsolo' (default) or 'dropest'
    aligner           = 'starsolo'

    // dropEst-specific parameters (required when --aligner dropest)
    dropest_container = null   // path/URI to dropEst Singularity/Docker image
    gtf               = null   // path to GTF annotation file
    droptag_v3_xml    = "${projectDir}/../inputs/indrop_v3.xml"
    droptag_v2_xml    = "${projectDir}/../inputs/indrop_v1_2.xml"

    // dropEst resource defaults
    dropest_mem       = "80 GB"
    dropest_time      = "8h"
    dropest_threads   = 20

    // Resource Defaults (matched to your pipeline script)
    star_threads     = 20
    star_mem         = "32 GB"
    star_time        = "4h"
    cutadapt_threads = 20
    cutadapt_mem     = "12 GB"
    cutadapt_time    = "2h"
    seqtk_mem        = "32 GB"
    seqtk_time       = "4h"
    fastqc_threads   = 6
    fastqc_mem       = "4 GB"
    fastqc_time      = "2h"
    multiqc_mem      = "4 GB"
    multiqc_time     = "1h"
}

// 2. Global Process Settings (Labels & Containers)
process {
    // Retry on SLURM OOM (137) / timeout (140) / segfault (139)
    errorStrategy = { task.exitStatus in [137, 139, 140] ? 'retry' : 'finish' }
    maxRetries    = 2

    withLabel: 'cutadapt' {
        container = 'docker://quay.io/biocontainers/cutadapt:5.2--py310h1fe012e_0'
        cpus      = params.cutadapt_threads
        memory    = { (params.cutadapt_mem as nextflow.util.MemoryUnit) * task.attempt }
        time      = { (params.cutadapt_time as nextflow.util.Duration) * task.attempt }
    }

    withLabel: 'seqtk' {
        container = 'docker://quay.io/biocontainers/seqtk:1.5--h577a1d6_1'
        memory    = { (params.seqtk_mem as nextflow.util.MemoryUnit) * task.attempt }
        time      = { (params.seqtk_time as nextflow.util.Duration) * task.attempt }
    }

    withLabel: 'star' {
        module    = 'star/2.7.11b:java/21.0.6'
        cpus      = params.star_threads
        memory    = { (params.star_mem as nextflow.util.MemoryUnit) * task.attempt }
        time      = { (params.star_time as nextflow.util.Duration) * task.attempt }
    }

    withLabel: 'fastqc' {
        container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
        cpus      = params.fastqc_threads
        memory    = { (params.fastqc_mem as nextflow.util.MemoryUnit) * task.attempt }
        time      = { (params.fastqc_time as nextflow.util.Duration) * task.attempt }
    }

    withLabel: 'multiqc' {
        container = 'quay.io/biocontainers/multiqc:1.33--pyhdfd78af_0'
        memory    = { (params.multiqc_mem as nextflow.util.MemoryUnit) * task.attempt }
        time      = { (params.multiqc_time as nextflow.util.Duration) * task.attempt }
    }

    withLabel: 'preflight' {
        memory    = { ('4 GB' as nextflow.util.MemoryUnit) * task.attempt }
        time      = { ('2h' as nextflow.util.Duration) * task.attempt }
    }

    withLabel: 'pystats' {
        conda     = 'python=3.12'
        memory    = '1 GB'
        time      = '30m'
    }

    withLabel: 'dropest' {
        container = params.dropest_container
        cpus      = params.dropest_threads
        memory    = { (params.dropest_mem as nextflow.util.MemoryUnit) * task.attempt }
        time      = { (params.dropest_time as nextflow.util.Duration) * task.attempt }
    }
}

// 3. Profiles for Infrastructure
profiles {
    hpc {
        process {
            executor = 'slurm'
            queue    = 'dev'
        }
        singularity {
            enabled    = true
            autoMounts = true
            runOptions = '--bind /mnt/beegfs/home/asalamit/persistent'
        }
        conda {
            enabled  = true
            useMamba = true
            cacheDir = '/mnt/beegfs/home/asalamit/persistent/nf_conda_envs'
        }
        env.PATH = "/mnt/beegfs/common/apps/miniforge/25.3.1/bin:\${PATH}"
        workDir = "/mnt/beegfs/home/asalamit/persistent/nf_work"
    }

    local {
        process {
            executor = 'local'
        }
        singularity.enabled = true
    }
}

// 4. Reporting
timeline { enabled = true; file = "pipeline_timeline.html" }
report   { enabled = true; file = "pipeline_report.html" }
